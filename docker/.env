## Agent image
MG_AGENT_IMAGE=ghcr.io/absmach/agent:latest

## HTTP
MG_AGENT_HTTP_PORT=9999

## MQTT
## Note: For Magistrala cloud set variables as follows:
# MG_AGENT_MQTT_URL=ssl://messaging.magistrala.absmach.eu:8883
# MG_AGENT_MQTT_SKIP_TLS=false
MG_AGENT_MQTT_URL=ssl://host.docker.internal:8883
MG_AGENT_MQTT_SKIP_TLS=true

MG_AGENT_MQTT_MTLS=false

## Internal services
MG_AGENT_NODERED_URL=http://nodered:1880/

## Timers
MG_AGENT_HEARTBEAT_INTERVAL=10s
MG_AGENT_TERMINAL_SESSION_TIMEOUT=60s

## OTA
MG_AGENT_OTA_ENABLED=true
MG_AGENT_OTA_BINARY_PATH=/usr/local/bin/agent
MG_AGENT_OTA_DOWNLOAD_DIR=/tmp

## Bootstrap
MG_AGENT_BOOTSTRAP_EXTERNAL_ID=""
MG_AGENT_BOOTSTRAP_EXTERNAL_KEY=""
MG_AGENT_BOOTSTRAP_URL=http://bootstrap:9013/clients/bootstrap
MG_AGENT_BOOTSTRAP_RETRIES=5
MG_AGENT_BOOTSTRAP_RETRY_DELAY_SECONDS=10
MG_AGENT_BOOTSTRAP_SKIP_TLS=false

## Device Manager
MG_AGENT_DEVICE_DB_PATH=/var/lib/agent/devices.db

## Config Store
MG_AGENT_CONFIG_PATH=/var/lib/agent/agent-config.json

MG_AGENT_CLIENTS_URL="http://host.docker.internal:9006"
MG_AGENT_CHANNELS_URL="http://host.docker.internal:9005"
MG_AGENT_RULES_ENGINE_URL="http://host.docker.internal:9008"
MG_PAT=""
