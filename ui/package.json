{
  "name": "magistrala-agent-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && mkdir -p dist && mkdir -p dist/assets && touch dist/.gitkeep && touch dist/assets/.gitkeep",
    "preview": "vite preview",
    "lint": "biome check --error-on-warnings src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wterm/dom": "^0.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "preact": "^10.29.3",
    "preact-iso": "^2.9.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@preact/preset-vite": "^2.9.5",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.2"
  }
}
